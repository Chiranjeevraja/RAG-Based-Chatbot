# ── OpenAI ──────────────────────────────────────────────
# Required: used for embeddings (text-embedding-3-small) and chat (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# ── Qdrant Cloud ─────────────────────────────────────────
# Required: vector database for storing and searching chunks.
# Sign up free at https://cloud.qdrant.io/
# Create a cluster → copy the URL and API key.
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# ── YouTube Data API v3 ──────────────────────────────────
# Required for fetching video comments and metadata.
# Get one free at: https://console.cloud.google.com/
# Enable "YouTube Data API v3" in your project.
YOUTUBE_API_KEY=AIza...
